---
import { nav, site } from "../data/site";
---

<header class="site-header">
  <div class="site-header__inner container">
    <a href="#" class="site-header__brand" aria-label={site.name}>
      <img src="/images/logo.png" alt="" width="120" height="40" class="site-header__logo" />
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      {
        nav.map((item) => (
          <a href={item.href} class="site-header__link">
            {item.label}
          </a>
        ))
      }
    </nav>
    <a href={site.portfolioUrl} class="site-header__cta btn btn--dark" download>
      Portfolio
    </a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    padding: 1.25rem 0;
    transition:
      background var(--transition),
      backdrop-filter var(--transition),
      border-color var(--transition),
      padding var(--transition);
  }

  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 0;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-header__logo {
    height: 2rem;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: filter var(--transition);
  }

  .site-header.is-scrolled .site-header__logo {
    filter: none;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 2.25rem;
  }

  .site-header__link {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    transition: color var(--transition);
  }

  .site-header.is-scrolled .site-header__link {
    color: var(--text-secondary);
  }

  .site-header__link:hover {
    color: var(--white);
  }

  .site-header.is-scrolled .site-header__link:hover {
    color: var(--black);
  }

  .site-header__cta {
    padding: 0.65rem 1.25rem;
    font-size: 0.625rem;
  }

  .site-header:not(.is-scrolled) .site-header__cta {
    background: rgba(255, 255, 255, 0.12);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .site-header:not(.is-scrolled) .site-header__cta:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 900px) {
    .site-header__nav {
      display: flex;
    }
  }
</style>
