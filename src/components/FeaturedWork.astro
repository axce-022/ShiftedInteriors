---
import { featuredWork } from "../data/site";
---

<section class="work" id="work">
  <div class="work__inner container">
    <header class="work__header">
      <p class="eyebrow reveal">Content Performance</p>
      <h2 class="section-heading reveal reveal-delay-1">Featured Work</h2>
      <hr class="divider reveal reveal-delay-2" />
      <p class="section-lead reveal reveal-delay-2">
        Our most viewed transformations — organically reaching tens of millions
        of viewers across social media.
      </p>
    </header>

    <div class="work__grid">
      {
        featuredWork.map((item, i) => (
          <article
            class:list={[
              "work__item",
              "reveal",
              `reveal-delay-${Math.min((i % 4) + 1, 4)}`,
            ]}
          >
            <div class="work__image">
              <img src={item.image} alt={`${item.title} transformation`} loading="lazy" />
            </div>
            <div class="work__meta">
              <h3 class="work__title">{item.title}</h3>
              <p class="work__views">{item.views}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work {
    padding: var(--section-y) 0;
    background: var(--white);
  }

  .work__inner {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 4.5rem);
  }

  .work__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 36rem;
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  .work__item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .work__image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0f0;
  }

  .work__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 1.2s var(--ease);
  }

  .work__item:hover .work__image img {
    transform: scale(1.03);
  }

  .work__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .work__title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .work__views {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  @media (min-width: 600px) {
    .work__grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
  }

  @media (min-width: 1000px) {
    .work__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
