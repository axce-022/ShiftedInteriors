---
import { site, social } from "../data/site";
---

<section class="contact" id="contact">
  <div class="contact__bg" aria-hidden="true">
    <img src="/images/contact-bg.png" alt="" width="1920" height="1080" loading="lazy" />
  </div>

  <div class="contact__inner container">
    <div class="contact__content reveal">
      <p class="eyebrow contact__eyebrow">Partnerships</p>
      <h2 class="contact__headline">
        Let's Build<br />Something Extraordinary
      </h2>
      <hr class="divider divider--center" />

      <a href={`mailto:${site.email}`} class="contact__email">
        {site.email}
      </a>

      <div class="contact__social">
        {
          social.map((s) => (
            <a
              href={s.href}
              class="contact__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
            >
              <img src={s.icon} alt="" width="24" height="24" />
            </a>
          ))
        }
      </div>

      <a href={site.portfolioUrl} class="btn btn--dark contact__cta" download>
        Download Partnership Portfolio
      </a>
    </div>

    <footer class="contact__footer">
      <img
        src="/images/logo-mark.png"
        alt=""
        width="48"
        height="48"
        class="contact__logo"
      />
      <p class="contact__footer-text">
        &copy; {new Date().getFullYear()} {site.name}. Working With Brands Worldwide.
      </p>
    </footer>
  </div>
</section>

<style>
  .contact {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--section-y) 0 3rem;
    overflow: hidden;
  }

  .contact__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .contact__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .contact__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(4rem, 10vw, 6rem);
  }

  .contact__content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 36rem;
  }

  .contact__eyebrow {
    color: var(--text-muted);
  }

  .contact__headline {
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .contact__email {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--black);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition);
  }

  .contact__email:hover {
    border-color: var(--black);
  }

  .contact__social {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0;
  }

  .contact__social-link {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    opacity: 0.65;
    transition: opacity var(--transition);
  }

  .contact__social-link:hover {
    opacity: 1;
  }

  .contact__social-link img {
    width: 1.25rem;
    height: 1.25rem;
    object-fit: contain;
  }

  .contact__cta {
    margin-top: 0.5rem;
  }

  .contact__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .contact__logo {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
    opacity: 0.85;
  }

  .contact__footer-text {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
</style>
