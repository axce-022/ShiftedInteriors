---
import { partnershipReasons } from "../data/site";
---

<section class="partnerships" id="partnerships">
  <div class="partnerships__inner container">
    <header class="partnerships__header">
      <p class="eyebrow reveal">Partnership Value</p>
      <h2 class="section-heading reveal reveal-delay-1">
        Why Brands Partner With Us
      </h2>
      <hr class="divider reveal reveal-delay-2" />
    </header>

    <div class="partnerships__grid">
      {
        partnershipReasons.map((item, i) => (
          <article class={`partnerships__card reveal reveal-delay-${Math.min((i % 3) + 1, 4)}`}>
            <span class="partnerships__index">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="partnerships__title">{item.title}</h3>
            <p class="partnerships__desc">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partnerships {
    padding: var(--section-y) 0;
    background: #fafafa;
    border-top: 1px solid var(--border);
  }

  .partnerships__inner {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 4.5rem);
  }

  .partnerships__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 36rem;
  }

  .partnerships__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .partnerships__card {
    background: var(--white);
    padding: clamp(2rem, 4vw, 2.75rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background var(--transition);
  }

  .partnerships__card:hover {
    background: #fcfcfc;
  }

  .partnerships__index {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--text-muted);
  }

  .partnerships__title {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .partnerships__desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 28rem;
  }

  @media (min-width: 640px) {
    .partnerships__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .partnerships__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
